<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ver Tablas"
        style="@style/TituloPantalla"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnTabTablas"
            style="@style/BotonPrimario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Tablas"/>

        <Button
            android:id="@+id/btnTabPacientes"
            style="@style/BotonPrimario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:backgroundTint="@color/accent"
            android:text="Pac/Doc"/>

        <Button
            android:id="@+id/btnTabGestor"
            style="@style/BotonPrimario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="@color/danger"
            android:text="Gestor"/>

    </LinearLayout>

    <!-- Vista 1: Tablas -->
    <LinearLayout
        android:id="@+id/layoutTablas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <Spinner
            android:id="@+id/spinnerTablas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="12dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tvContenidoTabla"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Vista 2: Pacientes con su doctor -->
    <ScrollView
        android:id="@+id/layoutPacientes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvPacientesDoctor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace"/>

        </LinearLayout>
    </ScrollView>

    <!-- Vista 3: Gestor (actualizar / eliminar) -->
    <ScrollView
        android:id="@+id/layoutGestor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:elevation="2dp">

            <Spinner
                android:id="@+id/spinnerGestorTabla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etGestorId"
                style="@style/InputTexto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ID del registro"/>

            <Button
                android:id="@+id/btnGestorBuscar"
                style="@style/BotonPrimario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Buscar"/>

            <LinearLayout
                android:id="@+id/contenedorCamposGestor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"/>

            <Button
                android:id="@+id/btnGestorActualizar"
                style="@style/BotonPrimario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Actualizar"
                android:layout_marginTop="10dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnGestorEliminar"
                style="@style/BotonPrimario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/danger"
                android:text="Eliminar registro"
                android:layout_marginTop="10dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvResultadoGestor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/success"
                android:layout_marginTop="10dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>