<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar Usuario o Médico"
        style="@style/TituloPantalla"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnTabMedico"
            style="@style/BotonPrimario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Nuevo Médico"/>

        <Button
            android:id="@+id/btnTabUsuario"
            style="@style/BotonPrimario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:backgroundTint="@color/accent"
            android:text="Nuevo Usuario"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- FORMULARIO MÉDICO -->
            <LinearLayout
                android:id="@+id/layoutMedico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:elevation="2dp">

                <EditText android:id="@+id/etMedNombre"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre"/>

                <EditText android:id="@+id/etMedApellidoPaterno"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Apellido paterno"/>

                <EditText android:id="@+id/etMedApellidoMaterno"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Apellido materno"/>

                <EditText android:id="@+id/etMedCedula"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Cédula profesional"/>

                <EditText android:id="@+id/etMedTelefono"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Teléfono"
                    android:inputType="phone"/>

                <EditText android:id="@+id/etMedEspecialidad"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Especialidad"/>

                <Button android:id="@+id/btnGuardarMedico"
                    style="@style/BotonPrimario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Guardar médico"
                    android:layout_marginTop="6dp"/>

                <TextView android:id="@+id/tvResultadoMedico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/success"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <!-- FORMULARIO USUARIO -->
            <LinearLayout
                android:id="@+id/layoutUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:elevation="2dp"
                android:visibility="gone">

                <EditText android:id="@+id/etUsrUsuario"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre de usuario"/>

                <EditText android:id="@+id/etUsrPassword"
                    style="@style/InputTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contraseña"
                    android:inputType="textPassword"/>

                <Button android:id="@+id/btnGuardarUsuario"
                    style="@style/BotonPrimario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Guardar usuario"
                    android:layout_marginTop="6dp"/>

                <TextView android:id="@+id/tvResultadoUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/success"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>